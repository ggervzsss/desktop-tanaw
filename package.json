{
  "name": "desktop-tanaw",
  "private": true,
  "version": "0.0.0",
  "description": "TANAW Enterprise Desktop application for local enterprise monitoring and reporting.",
  "author": "City Government of San Pedro",
  "type": "module",
  "scripts": {
    "dev": "node scripts/with-electron-env.cjs vite --host 127.0.0.1",
    "dev:docker": "vite --host 0.0.0.0 --port 5174",
    "build": "tsc && vite build",
    "dist": "npm run build && electron-builder",
    "start": "node scripts/with-electron-env.cjs electron .",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "node scripts/with-electron-env.cjs electron .",
    "preview:web": "vite preview",
    "prettier": "prettier --write .",
    "type": "tsc --noEmit"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@tanstack/react-query": "^5.100.10",
    "axios": "^1.16.1",
    "lucide-react": "^1.16.0",
    "motion": "^12.38.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hot-toast": "^2.6.0",
    "react-router-dom": "^7.15.1",
    "recharts": "^3.8.1",
    "tailwindcss": "^4.3.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@types/react": "^18.2.64",
    "@types/react-dom": "^18.2.21",
    "@typescript-eslint/eslint-plugin": "^7.1.1",
    "@typescript-eslint/parser": "^7.1.1",
    "@vitejs/plugin-react": "^4.2.1",
    "electron": "^30.0.1",
    "electron-builder": "^24.13.3",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "typescript": "^5.5.4",
    "vite": "^5.1.6",
    "vite-plugin-electron": "^0.28.6",
    "vite-plugin-electron-renderer": "^0.14.5"
  },
  "main": "dist-electron/main.js"
}
